<% layout("/layouts/boilerplate") -%>

<div class="row mt-4">
    <div class="col-md-8 offset-md-2">

        <h2 class="mb-4">Edit Your Listing</h2>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">

            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input
                    id="title"
                    name="listing[title]"
                    value="<%= listing.title %>"
                    type="text"
                    class="form-control"
                    required>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea
                    id="description"
                    name="listing[description]"
                    class="form-control"
                    rows="4"><%= listing.description %></textarea>
            </div>

            <div class="mb-3">
                <label for="image" class="form-label">Image URL</label>
                <input
                    id="image"
                    name="listing[image][url]"
                    value="<%= listing.image.url %>"
                    type="text"
                    class="form-control">
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label for="price" class="form-label">Price</label>
                    <input
                        id="price"
                        name="listing[price]"
                        value="<%= listing.price %>"
                        type="number"
                        class="form-control">
                </div>

                <div class="col-md-8 mb-3">
                    <label for="country" class="form-label">Country</label>
                    <input
                        id="country"
                        name="listing[country]"
                        value="<%= listing.country %>"
                        type="text"
                        class="form-control">
                </div>

            </div>

            <div class="mb-4">
                <label for="location" class="form-label">Location</label>
                <input
                    id="location"
                    name="listing[location]"
                    value="<%= listing.location %>"
                    type="text"
                    class="form-control">
            </div>

            <button type="submit" class="btn edit-btn px-4 py-2">
                Update 
            </button>

        </form>

    </div>
</div>